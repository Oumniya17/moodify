<!DOCTYPE html>
<html>
<head>
  <title>Explorar - Moodify</title>

  <!-- TIPOGRAFIA -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      background: #0d0d0d;
      color: white;
    }

    /* NAVBAR */
    .navbar {
      position: fixed;
      top: 0;
      width: 100%;
      padding: 20px 50px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 3000;
      background: linear-gradient(to bottom, rgba(0,0,0,0.9), transparent);
      transition: 0.3s;
    }

    .modal-open .navbar {
      background: rgba(0,0,0,0.95);
      backdrop-filter: blur(10px);
    }

    .logo a {
      text-decoration: none;
      color: white;
      font-size: 1.8rem;
      font-weight: 700;
    }

    .logo .m {
      color: #e50914;
      font-size: 2.2rem;
    }

    .menu a {
      color: #aaa;
      text-decoration: none;
      margin-left: 25px;
      transition: 0.3s;
      font-weight: 400;
    }

    .menu a:hover {
      color: white;
    }

    .menu .active {
      color: white;
      font-weight: 600;
    }

    /* HERO */
    .hero {
      padding: 110px 50px 20px;
    }

    .hero h1 {
      font-size: 1.9rem;
      font-weight: 600;
      letter-spacing: 0.5px;

      text-shadow:
        0 0 8px rgba(255,255,255,0.08),
        0 0 15px rgba(229,9,20,0.2);
    }

    .hero p {
      color: #aaa;
      font-size: 0.9rem;
      margin-top: 6px;
      font-weight: 300;
    }

    /* GRID */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 25px;
      padding: 25px 50px 80px;
    }

    /* CARD */
    .card {
      position: relative;
      overflow: hidden;
      border-radius: 12px;
      cursor: pointer;
      transition: 0.3s;

      border: 1px solid rgba(255,255,255,0.05);
    }

    .card img {
      width: 100%;
      transition: 0.4s;
    }

    .card:hover {
      transform: scale(1.08);
      z-index: 10;
    }

    .card:hover img {
      transform: scale(1.15);
    }

    /* MODAL */
    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.9);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 2000;
    }

    .modal-content {
      background: #141414;
      border-radius: 15px;
      overflow: hidden;
      width: 80%;
      max-width: 850px;
      box-shadow: 0 0 40px rgba(0,0,0,0.8);
    }

    .modal-hero {
      height: 320px;
      background-size: cover;
      background-position: center;
      position: relative;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, #141414, transparent);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 20px;
    }

    .title-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .title-row h2 {
      font-size: 1.8rem;
      font-weight: 600;
    }

    .rating-badge {
      background: rgba(255,255,255,0.1);
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      box-shadow:
        0 0 10px rgba(255,255,255,0.2),
        0 0 20px rgba(255,255,255,0.1);
    }

    .play-big {
      margin-top: 15px;
      padding: 14px 25px;
      background: linear-gradient(90deg, #ffffff, #e5e5e5);
      color: black;
      border: none;
      border-radius: 8px;
      font-weight: bold;
      cursor: pointer;

      box-shadow:
        0 0 15px rgba(255,255,255,0.4),
        0 0 30px rgba(255,255,255,0.2);

      transition: 0.25s;
    }

    .play-big:hover {
      transform: scale(1.05);
    }

    .modal-body {
      padding: 20px;
    }

    .modal-body p {
      color: #ccc;
      margin-bottom: 10px;
      line-height: 1.5;
    }

    iframe {
      width: 100%;
      height: 400px;
      border: none;
    }

    .close-btn {
      margin-top: 15px;
      padding: 12px 20px;
      background: linear-gradient(90deg, #e50914, #ff2a2a);
      border: none;
      border-radius: 8px;
      color: white;
      cursor: pointer;

      box-shadow:
        0 0 15px rgba(229,9,20,0.6),
        0 0 25px rgba(229,9,20,0.3);
    }

  </style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">

  <div class="logo">
    <a href="/"><span class="m">M</span>oodify</a>
  </div>

  <div class="menu">
    <a href="/explore" class="active">Explorar</a>
    <a href="/vibes">Vibes</a>
    <a href="/docs">Cómo funciona</a>
  </div>

</div>

<!-- HERO -->
<div class="hero">
  <h1>🔥 En tendencia</h1>
  <p>Lo que el mundo está viendo ahora mismo...</p>
</div>

<!-- GRID -->
<div class="grid">
  <% movies.forEach(movie => { %>
    <div class="card" onclick="openMovie(<%= movie.id %>)">
      <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>">
    </div>
  <% }) %>
</div>

<!-- MODAL -->
<div class="modal" id="modal">
  <div class="modal-content" id="modal-content"></div>
</div>

<script>
async function openMovie(id) {
  document.body.classList.add("modal-open");

  const res = await fetch(`/movie/${id}`);
  const movie = await res.json();

  document.getElementById("modal-content").innerHTML = `
    <div class="modal-hero" style="background-image:url('https://image.tmdb.org/t/p/original${movie.backdrop_path}')">
      <div class="hero-overlay">

        <div class="title-row">
          <h2>${movie.title}</h2>
          <div class="rating-badge">⭐ ${movie.vote_average.toFixed(1)}</div>
        </div>

        <button class="play-big" onclick="playTrailer(${id})">
          ▶ Reproducir
        </button>

      </div>
    </div>

    <div class="modal-body">
      <p>${movie.overview}</p>
      <button class="close-btn" onclick="closeModal()">Cerrar</button>
    </div>
  `;

  document.getElementById("modal").style.display = "flex";
}

async function playTrailer(id) {
  const res = await fetch(`/movie/${id}/trailer`);
  const data = await res.json();

  if (!data.key) {
    alert("No hay trailer 😢");
    return;
  }

  document.getElementById("modal-content").innerHTML = `
    <iframe src="https://www.youtube.com/embed/${data.key}?autoplay=1"></iframe>
    <button class="close-btn" onclick="closeModal()">Cerrar</button>
  `;
}

function closeModal() {
  document.body.classList.remove("modal-open");

  const modal = document.getElementById("modal");
  const content = document.getElementById("modal-content");

  modal.style.display = "none";
  content.innerHTML = "";
}

window.onclick = function(e) {
  if (e.target.id === "modal") {
    closeModal();
  }
};
</script>

</body>
</html>